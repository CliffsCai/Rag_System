# ==================== 阿里云凭据 ====================
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# ==================== LLM 配置 ====================
DASHSCOPE_API_KEY=
LLM_MODEL=qwen-plus
LANGSMITH_TRACING=

# ==================== ADB 向量数据库 ====================
BAILIAN_ADB_ENABLED=
BAILIAN_ADB_HOST=
BAILIAN_ADB_PORT=
BAILIAN_ADB_DATABASE=
BAILIAN_ADB_USER=
BAILIAN_ADB_PASSWORD=
BAILIAN_ADB_TABLE=
ADBPG_INSTANCE_ID=
ADBPG_INSTANCE_REGION=
ADB_NAMESPACE=
ADB_NAMESPACE_PASSWORD=
ADB_COLLECTION=
# ADB_SQL_SECRET_ARN 留空，由程序自动通过 ListSecrets 查找或 CreateSecret 创建

# ==================== 向量检索配置 ====================
VECTOR_DIMENSION=1536
VECTOR_TOP_K=10
VECTOR_SCORE_THRESHOLD=0

# ==================== 文档上传配置 ====================
ADB_DOCUMENT_LOADER_PDF=PDFWithImageRefLoader
#PyMuPDFLoader：.pdf
#PyPDFLoader：.pdf
#RapidOCRPDFLoader：.pdf
#PDFWithImageRefLoader：.pdf (with the text-image association feature)
ADB_TEXT_SPLITTER=ChineseRecursiveTextSplitter
#ChineseRecursiveTextSplitter：继承于RecursiveCharacterTextSplitter，默认以["\n\n","\n", "。|！|？","\.\s|\!\s|\?\s", "；|;\s", "，|,\s"]作为分隔符，使用正则匹配，中文比 RecursiveCharacterTextSplitter效果更好一些。
#SpacyTextSplitter：默认以["\n\n", "\n", " ", ""]作为分隔符。可以支持c++、go、java、js、php、proto、python、rst、ruby、rust、scala、swift、markdown、latex、html、sol、csharp等多种代码语言的切分。
#RecursiveCharacterTextSplitter：默认分隔符为\n\n，使用Spacy库的en_core_web_sm模型来分隔，对全英文文档支持较好。
#MarkdownHeaderTextSplitter：针对markdown类型，使用[ ("#", "head1"), ("##", "head2"), ("###", "head3"), ("####", "head4") ]来切分。

# ==================== 切片清洗配置 ====================
LLM_CLEAN_MODEL=qwen-turbo

# ==================== 多租户加密密钥 ====================
# 用于加密存储命名空间密码，32字节hex，勿泄露
NAMESPACE_ENCRYPT_KEY=

# ==================== OSS 配置 ====================
OSS_BUCKET=
OSS_REGION=  # 默认 cn-shanghai，如需修改请取消注释
OSS_ENDPOINT=

# ==================== API 配置 ====================
API_HOST=0.0.0.0
API_PORT=8000
SSL_VERIFY=false
